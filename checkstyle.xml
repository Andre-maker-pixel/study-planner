<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">

  <property name="severity" value="error"/>
  <property name="fileExtensions" value="java"/>

  <module name="TreeWalker">

    <!-- Nomes de classes em PascalCase -->
    <module name="TypeName"/>

    <!-- Nomes de métodos em camelCase -->
    <module name="MethodName"/>

    <!-- Nomes de variáveis em camelCase -->
    <module name="LocalVariableName"/>

    <!-- Chaves obrigatórias em if/else/for/while -->
    <module name="NeedBraces"/>

    <!-- Imports não utilizados -->
    <module name="UnusedImports"/>

    <!-- Imports duplicados -->
    <module name="RedundantImport"/>

    <!-- Espaço após vírgulas -->
    <module name="WhitespaceAfter">
      <property name="tokens" value="COMMA"/>
    </module>

    <!-- Linha não pode ter espaços em branco no final -->
    <module name="Regexp">
      <property name="format" value="[ \t]+$"/>
      <property name="illegalPattern" value="true"/>
      <property name="message" value="Trailing whitespace not allowed."/>
    </module>

  </module>

  <!-- Tamanho máximo de linha: 120 caracteres -->
  <module name="LineLength">
    <property name="max" value="120"/>
  </module>

  <!-- Arquivo deve terminar com nova linha -->
  <module name="NewlineAtEndOfFile"/>

</module>